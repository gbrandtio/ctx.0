{
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "app-api",
    "Audience": "app-mobile-client",
    "SigningKey": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Security": {
    "Encryption": {
      "CurrentVersion": "",
      "Keys": {},
      "BlindIndexKey": ""
    },
    "Ale": {
      "RsaPrivateKey": "",
      "RsaPublicKey": "",
      "Enforced": true,
      "SignatureWindowSeconds": 300,
      "RequestSigningRequired": true
    }
  },
  "Stripe": {
    "SecretKey": "",
    "WebhookSecret": ""
  },
  "Authentication": {
    "Google": {
      "ClientIds": []
    }
  },
  "Rbac": {
    "Roles": {},
    "Assignments": {}
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
