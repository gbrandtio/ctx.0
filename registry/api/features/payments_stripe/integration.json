{
  "id": "payments_stripe",
  "summary": "Stripe payment intents + webhook + SSE payment events (ships enabled)",
  "providesNavTab": false,
  "markedFiles": [
    "Infrastructure/Infrastructure.csproj",
    "AppApi/AppApi.csproj",
    "AppApi/Program.cs",
    "AppApi/Extensions/ServiceCollectionExtensions.cs",
    "Application/Application.csproj",
    "tests/UnitTests/UnitTests.csproj"
  ],
  "sourceDirs": [],
  "testDirs": [],
  "envVars": [
    "Stripe__SecretKey",
    "Stripe__WebhookSecret"
  ],
  "userSteps": [
    "Set the Stripe secret key and webhook signing secret (https://dashboard.stripe.com); point the webhook at POST /v1/payments/stripe-webhook (docs/features/PAYMENTS_STRIPE.md).",
    "Mobile counterpart: `ctx0 enable payments_stripe` in the app repo."
  ],
  "injections": {
    "Infrastructure/Infrastructure.csproj": [
      "    <CtxPaymentsStripe>true</CtxPaymentsStripe>"
    ],
    "AppApi/AppApi.csproj": [
      "    <CtxPaymentsStripe>true</CtxPaymentsStripe>"
    ],
    "AppApi/Program.cs": [
      "builder.Services.AddHostedService<PostgresPaymentUpdateListener>();",
      "    new PaymentsEndpoints(),"
    ],
    "AppApi/Extensions/ServiceCollectionExtensions.cs": [
      "        services.Configure<StripeOptions>(configuration.GetSection(StripeOptions.SectionName));",
      "        services.AddSingleton<IPaymentGateway, StripePaymentGateway>();"
    ],
    "Application/Application.csproj": [
      "    <CtxPaymentsStripe>true</CtxPaymentsStripe>"
    ],
    "tests/UnitTests/UnitTests.csproj": [
      "    <CtxPaymentsStripe>true</CtxPaymentsStripe>"
    ]
  }
}